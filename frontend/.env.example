# ──────────────────────────────────────────────────────────
# GeoTrade Intelligence Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# Anthropic Claude API Key — required for the GeoTrade AI chat assistant
# Get your key at: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application environment (development | production)
VITE_APP_ENV=production

# ── Optional flags ─────────────────────────────────────────
# Set to 'true' to always simulate a random API error on load (stress-test error handling)
# VITE_SIMULATE_ERRORS=false
